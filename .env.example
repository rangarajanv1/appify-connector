# Appify upstream
APPIFY_LOGIN_URL=https://login.appify.com
# Gateway Basic-auth header value sent to /api/toc/flex/login.
# Get this from a working Appify Postman collection (the "Authorization" header
# on the login request). Treat as a per-deploy secret — do not commit.
APPIFY_GATEWAY_AUTH=Basic REPLACE_ME

# Connector-issued JWT (used by API consumers)
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_TTL_SECONDS=43200

# Redis (sessions)
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=82800

# Misc
LOG_LEVEL=INFO
ENVIRONMENT=local
CORS_ALLOW_ORIGINS=

# Test-only (read by tests/conftest.py if you want to run real upstream tests)
# APPIFY_TEST_BUSINESS_NAME=
# APPIFY_TEST_EMAIL=
# APPIFY_TEST_PASSWORD=
